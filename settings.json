// mineflayer-bot/index.js
const mineflayer = require('mineflayer');
const express = require('express');
const cors = require('cors');

const app = express();
app.use(cors());
app.use(express.json());

let bot = null;
let chatLog = [];
let status = { connected: false, health: 20, food: 20, x: 0, y: 64, z: 0, dimension: 'overworld', username: 'Bot', ping: 0 };

function createBot() {
  bot = mineflayer.createBot({
    host: 'miniplayerss132.mcsh.io',
    port: 10975,
    username: 'ControlBot',
    version: false,
  });

  bot.on('spawn', () => {
    status.connected = true;
    status.username = bot.username;
    console.log('Bot spawned!');
  });

  bot.on('health', () => {
    status.health = bot.health;
    status.food = bot.food;
  });

  bot.on('move', () => {
    if (bot.entity) {
      status.x = Math.round(bot.entity.position.x);
      status.y = Math.round(bot.entity.position.y);
      status.z = Math.round(bot.entity.position.z);
    }
  });

  bot.on('chat', (username, message) => {
    chatLog.push({ id: Date.now(), author: username, text: message, timestamp: Date.now() });
    if (chatLog.length > 50) chatLog.shift();
  });

  bot.on('end', () => {
    status.connected = false;
    setTimeout(createBot, 5000);
  });

  bot.on('error', (err) => {
    console.error('Bot error:', err);
    status.connected = false;
  });
}

createBot();

app.get('/status', (req, res) => res.json(status));
app.get('/chat', (req, res) => res.json(chatLog));

app.post('/command', (req, res) => {
  const { type, message, direction, action } = req.body;
  if (!bot || !status.connected) return res.json({ ok: false, error: 'Bot not connected' });

  try {
    if (type === 'chat') {
      bot.chat(message);
    } else if (type === 'move') {
      if (direction === 'forward') bot.setControlState('forward', true), setTimeout(() => bot.setControlState('forward', false), 500);
      else if (direction === 'back') bot.setControlState('back', true), setTimeout(() => bot.setControlState('back', false), 500);
      else if (direction === 'left') bot.setControlState('left', true), setTimeout(() => bot.setControlState('left', false), 500);
      else if (direction === 'right') bot.setControlState('right', true), setTimeout(() => bot.setControlState('right', false), 500);
      else if (direction === 'jump') bot.setControlState('jump', true), setTimeout(() => bot.setControlState('jump', false), 500);
      else if (direction === 'sneak') bot.setControlState('sneak', true), setTimeout(() => bot.setControlState('sneak', false), 1000);
      else if (direction === 'sprint') bot.setControlState('sprint', true), setTimeout(() => bot.setControlState('sprint', false), 2000);
    } else if (type === 'action') {
      if (action === 'attack') bot.attack(bot.nearestEntity());
      else if (action === 'use') bot.activateItem();
      else if (action === 'drop') bot.tossStack(bot.heldItem);
      else if (action === 'disconnect') { bot.quit(); status.connected = false; }
      else if (action === 'reconnect') createBot();
    }
    res.json({ ok: true });
  } catch (e) {
    res.json({ ok: false, error: e.message });
  }
});

const PORT = process.env.PORT || 3000;
app.listen(PORT, () => console.log(`Bot API running on port ${PORT}`));
